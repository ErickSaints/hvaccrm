{
  "name": "hvaccrm-backend",
  "version": "1.0.0",
  "description": "HVAC-R CRM Backend",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && (cd .. && npm --prefix frontend install && npm --prefix frontend run build && cp -r frontend/dist public || echo 'Frontend build skipped')",
    "start": "npx prisma db push --accept-data-loss --skip-generate 2>/dev/null; npx tsx src/seed.ts 2>/dev/null; npx tsx src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
